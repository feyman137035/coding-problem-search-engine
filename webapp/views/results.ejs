<%- include('partials/header', { title: 'Search Results - Coding Problem Search' }) %>

  <div class="results-page">
    <a href="/" class="back-link">← New Search</a>

    <div class="results-info">
      <h2>Search Results for "<%= query %>"</h2>
      <p class="info-text">
        <% if (results.length > 0) { %>
          Found <%= results.length %> result<%= results.length !== 1 ? 's' : '' %> in <%= searchTime %>ms
        <% } %>
      </p>
    </div>

    <% if (results.length === 0) { %>
      <div class="no-results">
        <h3>No matching problems found.</h3>
        <p>Try different keywords or adjust your query.</p>
      </div>
    <% } else { %>
      <div class="results-list">
        <% results.forEach(function(result, index) { %>
          <div class="result-card">
            <div class="result-header">
              <span class="rank">#<%= index + 1 %></span>
              <h3 class="result-title"><%= result.doc.title %></h3>
            </div>
            <div class="result-meta">
              <span class="score">Relevance: <%= (result.score * 100).toFixed(2) %>%</span>
              <a href="<%= result.doc.url %>" target="_blank" rel="noopener noreferrer" class="view-link">View Problem →</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

<%- include('partials/footer') %>
